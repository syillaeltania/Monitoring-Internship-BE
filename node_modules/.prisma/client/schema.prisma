generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  HCM_STAFF
  HCM_LEADER
}

enum InternshipType {
  INSTITUTION
  PROFESSIONAL
}

enum InternshipStatus {
  PLANNED
  ACTIVE
  COMPLETED
  TERMINATED
}

enum ProcessStatus {
  REQUEST_RECEIVED
  SCREENING
  ACCEPTED
  ACCEPTANCE_LETTER_SENT
  WAITING_JOIN
  ACTIVE
  COMPLETED
  COMPLETION_CHECKLIST_DONE
}

enum ReplacementStatus {
  COVERED
  NEEDS_REPLACEMENT
  URGENT_EMPTY
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  role         UserRole
  division     String?
  team         String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Intern {
  id                   String               @id @default(cuid())
  name                 String
  type                 InternshipType
  institution          String?
  major                String?
  division             String
  team                 String
  position             String?
  leader               String?
  location             String?
  startDate            DateTime
  endDate              DateTime
  durationLabel        String?
  manualStatus         InternshipStatus?
  phone                String?
  email                String?
  notes                String?
  acceptanceLetterSent Boolean              @default(false)
  sourceSheet          String?
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  costs                MonthlyCost[]
  checklist            CompletionChecklist?
  evaluations          LeaderEvaluation[]

  @@unique([name, type, startDate, endDate])
  @@index([type, division, team])
  @@index([startDate, endDate])
}

model BenefitScheme {
  id                  String         @id @default(cuid())
  name                String
  type                InternshipType
  baseSalary          Int            @default(0)
  mealAllowancePerDay Int            @default(25000)
  notes               String?
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
  costs               MonthlyCost[]
}

model MonthlyCost {
  id                  String         @id @default(cuid())
  internId            String
  benefitSchemeId     String?
  month               Int
  year                Int
  baseSalary          Int            @default(0)
  mealAllowancePerDay Int            @default(25000)
  workingDays         Int            @default(0)
  attendanceDays      Int            @default(0)
  totalMealAllowance  Int            @default(0)
  totalMonthlyCost    Int            @default(0)
  intern              Intern         @relation(fields: [internId], references: [id], onDelete: Cascade)
  benefitScheme       BenefitScheme? @relation(fields: [benefitSchemeId], references: [id])

  @@unique([internId, month, year])
  @@index([year, month])
}

model InternshipPlan {
  id                   String         @id @default(cuid())
  name                 String
  type                 InternshipType
  institution          String?
  major                String?
  targetDivision       String
  targetTeam           String
  leader               String?
  acceptanceLetterDate DateTime?
  plannedStartDate     DateTime
  plannedEndDate       DateTime
  documentStatus       String?
  onboardingStatus     String?
  processStatus        ProcessStatus  @default(REQUEST_RECEIVED)
  phone                String?
  notes                String?
  sourceSheet          String?
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt

  @@unique([name, type, plannedStartDate])
}

model CompletionChecklist {
  id                     String   @id @default(cuid())
  internId               String   @unique
  leaderEvaluationForm   Boolean  @default(false)
  completionForm         Boolean  @default(false)
  certificate            Boolean  @default(false)
  accessReturned         Boolean  @default(false)
  assetReturned          Boolean  @default(false)
  finalReport            Boolean  @default(false)
  companyLaptopReturned  Boolean  @default(false)
  idCardReturned         Boolean  @default(false)
  companyEmailClosed     Boolean  @default(false)
  gitAccountClosed       Boolean  @default(false)
  knowledgeAccountClosed Boolean  @default(false)
  handoverCompleted      Boolean  @default(false)
  financeCleared         Boolean  @default(false)
  reportApproved         Boolean  @default(false)
  academyAccountClosed   Boolean  @default(false)
  leaderAssessmentFilled Boolean  @default(false)
  internFeedbackFilled   Boolean  @default(false)
  workGroupsLeft         Boolean  @default(false)
  finalStatus            String   @default("Belum Lengkap")
  notes                  String?
  intern                 Intern   @relation(fields: [internId], references: [id], onDelete: Cascade)
  updatedAt              DateTime @updatedAt
}

model TeamRequirement {
  id                      String            @id @default(cuid())
  division                String
  team                    String
  leader                  String?
  activeInstitutionCount  Int               @default(0)
  activeProfessionalCount Int               @default(0)
  minimumInstitutionNeed  Int               @default(1)
  endingInternName        String?
  soonestEndDate          DateTime?
  replacementStatus       ReplacementStatus @default(COVERED)
  replacementCandidate    String?
  hcmPic                  String?
  notes                   String?
  sourceSheet             String?

  @@unique([division, team])
}

model OrganizationUnit {
  id       String             @id @default(cuid())
  name     String
  type     String
  parentId String?
  leader   String?
  orderNo  Int                @default(0)
  parent   OrganizationUnit?  @relation("OrgTree", fields: [parentId], references: [id])
  children OrganizationUnit[] @relation("OrgTree")
}

model LeaderEvaluation {
  id        String   @id @default(cuid())
  internId  String
  score     Int?
  notes     String?
  evidence  String?
  intern    Intern   @relation(fields: [internId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}
